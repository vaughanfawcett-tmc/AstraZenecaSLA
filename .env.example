# Copy to .env and fill in. .env is gitignored.

# One LLM provider is required for Tier-2 categorisation (~40% of rows
# otherwise blank). Priority when multiple are set:
#   1. Azure OpenAI (AZURE_OPENAI_API_KEY + AZURE_OPENAI_ENDPOINT)
#   2. OpenAI direct (OPENAI_API_KEY)
#   3. OpenRouter (OPENROUTER_API_KEY)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Optional — enables Freshdesk transcript fetch for ambiguous tickets.
# Both must be set together.
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

# Tunables (optional)
# TIER2_MODEL=anthropic/claude-haiku-4.5
# TIER2_CONCURRENCY=8
